DOMAIN=books.example.com
WEBBOOK_ROOT=/opt/webbook
WEBBOOK_CONTENT_HOST_PATH=/opt/webbook/content
CONTENT_ROOT=content

AUTH_DISABLED=false
COOKIE_SECURE=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
SESSION_SECRET=

REDIS_URL=redis://redis:6379
PYTHON_RUNNER_URL=http://python-runner:8001/execute
PYTHON_TIMEOUT_SECONDS=5

EXECUTION_PER_MINUTE_LIMIT=5
EXECUTION_PER_HOUR_LIMIT=20

WEB_IMAGE=ghcr.io/nmorabowen/webbook-web:main
PYTHON_IMAGE=ghcr.io/nmorabowen/webbook-python-runner:main

BACKUP_LOCAL_DIR=/opt/webbook/backups/local
BACKUP_RETENTION_DAYS=14

RESTIC_REPOSITORY=s3:https://<bucket-endpoint>/webbook-prod
RESTIC_PASSWORD=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
