DOMAIN=books.example.com
WEBBOOK_ROOT=/opt/webbook
WEBBOOK_CONTENT_HOST_PATH=/opt/webbook/content
CONTENT_ROOT=content
SITE_URL=https://books.example.com

AUTH_DISABLED=false
COOKIE_SECURE=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
SESSION_SECRET=

NEXT_PUBLIC_GA_MEASUREMENT_ID=

WEB_IMAGE=webbook-web:local

BACKUP_LOCAL_DIR=/opt/webbook/backups/local
BACKUP_RETENTION_DAYS=14

RESTIC_REPOSITORY=s3:https://<bucket-endpoint>/webbook-prod
RESTIC_PASSWORD=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
