#!/usr/bin/env bash
set -euo pipefail

WEBBOOK_ROOT="${WEBBOOK_ROOT:-/opt/webbook}"
WEBBOOK_REPO_DIR="${WEBBOOK_REPO_DIR:-$WEBBOOK_ROOT/repo}"
WEBBOOK_ENV_FILE="${WEBBOOK_ENV_FILE:-$WEBBOOK_ROOT/.env.production}"
WEBBOOK_COMPOSE_FILE="${WEBBOOK_COMPOSE_FILE:-$WEBBOOK_REPO_DIR/docker-compose.production.yml}"
WEBBOOK_STATE_DIR="${WEBBOOK_STATE_DIR:-$WEBBOOK_ROOT/deploy/state}"

COMMON_SCRIPT="$WEBBOOK_REPO_DIR/deploy/common.sh"
INSTALL_SCRIPT="$WEBBOOK_REPO_DIR/deploy/install.sh"
DEPLOY_SCRIPT="$WEBBOOK_REPO_DIR/deploy/deploy.sh"
BACKUP_SCRIPT="$WEBBOOK_REPO_DIR/deploy/backup.sh"
RESTORE_SCRIPT="$WEBBOOK_REPO_DIR/deploy/restore.sh"
RENDER_CADDYFILE_SCRIPT="$WEBBOOK_REPO_DIR/deploy/render-caddyfile.sh"

usage() {
  cat <<'EOF'
Usage:
  webbookctl install
  webbookctl update [ref]
  webbookctl update --skip-backup-prompt [ref]
  webbookctl backup-url
  webbookctl status
  webbookctl logs [service]
  webbookctl backup
  webbookctl restore <backup-id>
  webbookctl rollback
  webbookctl update-config
  webbookctl doctor

The default 'update' flow pauses to remind you to download a workspace
backup through your admin browser session, then runs a server-side
backup, then deploys the requested ref. Pass --skip-backup-prompt for
unattended automation.
EOF
}

require_repo() {
  if [[ ! -f "$COMMON_SCRIPT" ]]; then
    echo "WebBook repo not found at $WEBBOOK_REPO_DIR" >&2
    exit 1
  fi
  # shellcheck disable=SC1090
  . "$COMMON_SCRIPT"
}

install_command() {
  if [[ -f "$INSTALL_SCRIPT" ]]; then
    exec "$INSTALL_SCRIPT" "$@"
  fi

  echo "Install script not found at $INSTALL_SCRIPT" >&2
  exit 1
}

status_command() {
  require_repo
  load_env

  echo "Domain: ${DOMAIN:-unset}"
  echo "Root: $WEBBOOK_ROOT"
  echo "Content path: ${WEBBOOK_CONTENT_HOST_PATH:-unset}"
  echo "Compose file: $WEBBOOK_COMPOSE_FILE"
  echo "Current repo ref: $(current_repo_ref)"
  echo
  compose ps
  echo
  if curl -fsS http://127.0.0.1:3000/api/healthz > /dev/null 2>&1; then
    echo "Web health: healthy"
  else
    echo "Web health: unhealthy"
  fi
}

logs_command() {
  require_repo
  local service="${1:-}"
  if [[ -n "$service" ]]; then
    compose logs --tail 200 -f "$service"
    return
  fi
  compose logs --tail 200 -f
}

update_command() {
  local skip_backup_prompt=0
  local target=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --skip-backup-prompt)
        skip_backup_prompt=1
        shift
        ;;
      --)
        shift
        target="${1:-}"
        break
        ;;
      *)
        target="$1"
        shift
        ;;
    esac
  done
  target="${target:-main}"

  require_repo
  load_env

  if (( skip_backup_prompt == 0 )); then
    prompt_for_browser_backup
  fi

  echo "Running server-side backup before update..."
  if ! "$BACKUP_SCRIPT"; then
    echo "Backup failed. Aborting update." >&2
    exit 1
  fi

  exec "$DEPLOY_SCRIPT" update "$target"
}

backup_url_command() {
  require_repo
  load_env
  print_browser_backup_url
}

print_browser_backup_url() {
  local domain="${DOMAIN:-}"
  if [[ -n "$domain" ]]; then
    printf 'https://%s/api/settings/general/export\n' "$domain"
  else
    printf '<your-domain>/api/settings/general/export\n'
    echo "(DOMAIN is not set in $WEBBOOK_ENV_FILE; substitute your real host)" >&2
  fi
}

prompt_for_browser_backup() {
  if [[ ! -t 0 ]]; then
    cat <<EOF >&2
Refusing to update without a TTY because the operator must confirm
they have downloaded a workspace backup. Re-run interactively, or
pass --skip-backup-prompt for unattended automation (e.g. CI/cron).
EOF
    exit 1
  fi

  local backup_dir="${BACKUP_LOCAL_DIR:-$WEBBOOK_ROOT/backups}"
  cat <<EOF
─────────────────────────────────────────────────────────────────────
  Backup before update
─────────────────────────────────────────────────────────────────────
  Download a workspace backup as an admin from your browser:

      $(print_browser_backup_url)

  This produces a webbook-workspace-*.zip with the full content tree,
  settings, and indexes — your off-server safety copy.

  A server-side backup will also be written to:
      ${backup_dir}

EOF

  local answer=""
  printf 'Have you downloaded the browser backup? [y/N] '
  read -r answer
  if [[ ! "$answer" =~ ^[Yy] ]]; then
    echo "Aborted. Run 'webbookctl update' again after backing up." >&2
    exit 1
  fi
}

rollback_command() {
  require_repo
  exec "$DEPLOY_SCRIPT" rollback
}

backup_command() {
  require_repo
  exec "$BACKUP_SCRIPT"
}

restore_command() {
  local backup_id="${1:-}"
  if [[ -z "$backup_id" ]]; then
    usage
    exit 1
  fi

  require_repo
  exec "$RESTORE_SCRIPT" "$backup_id"
}

update_config_command() {
  require_repo
  local caddy_file="/etc/caddy/Caddyfile.d/webbook.conf"

  mkdir -p /etc/caddy/Caddyfile.d
  "$RENDER_CADDYFILE_SCRIPT" > "$caddy_file"

  if [[ ! -f /etc/caddy/Caddyfile ]]; then
    cat > /etc/caddy/Caddyfile <<'EOF'
import /etc/caddy/Caddyfile.d/*
EOF
  elif ! grep -q '^import /etc/caddy/Caddyfile.d/\*$' /etc/caddy/Caddyfile; then
    printf '\nimport /etc/caddy/Caddyfile.d/*\n' >> /etc/caddy/Caddyfile
  fi

  systemctl reload caddy || systemctl restart caddy
  echo "Caddy configuration updated."
}

doctor_command() {
  require_repo

  local failures=0
  local required_commands=(docker git caddy curl jq restic)
  local command_name

  for command_name in "${required_commands[@]}"; do
    if command -v "$command_name" > /dev/null 2>&1; then
      echo "[ok] $command_name"
    else
      echo "[missing] $command_name"
      failures=1
    fi
  done

  for path in "$WEBBOOK_ENV_FILE" "$WEBBOOK_COMPOSE_FILE"; do
    if [[ -f "$path" ]]; then
      echo "[ok] $path"
    else
      echo "[missing] $path"
      failures=1
    fi
  done

  if (( failures != 0 )); then
    exit 1
  fi

  compose config > /dev/null
  echo "[ok] docker compose configuration"
}

main() {
  local command="${1:-}"
  shift || true

  case "$command" in
    install)
      install_command "$@"
      ;;
    update|deploy)
      update_command "$@"
      ;;
    backup-url)
      backup_url_command
      ;;
    status)
      status_command
      ;;
    logs)
      logs_command "$@"
      ;;
    backup)
      backup_command
      ;;
    restore)
      restore_command "$@"
      ;;
    rollback)
      rollback_command
      ;;
    update-config)
      update_config_command
      ;;
    doctor)
      doctor_command
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
