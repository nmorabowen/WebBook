    },
    {
      "page": "/app/books/[bookSlug]",
      "regex": "^/app/books/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPbookSlug": "nxtPbookSlug"
      },
      "namedRegex": "^/app/books/(?<nxtPbookSlug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/app/books/[bookSlug]/chapters/[chapterSlug]",
      "regex": "^/app/books/([^/]+?)/chapters/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPbookSlug": "nxtPbookSlug",
        "nxtPchapterSlug": "nxtPchapterSlug"
      },
      "namedRegex": "^/app/books/(?<nxtPbookSlug>[^/]+?)/chapters/(?<nxtPchapterSlug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/app/notes/[slug]",
