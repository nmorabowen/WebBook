      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/app/notes/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/books/[bookSlug]",
      "regex": "^/books/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPbookSlug": "nxtPbookSlug"
      },
      "namedRegex": "^/books/(?<nxtPbookSlug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/books/[bookSlug]/[chapterSlug]",
      "regex": "^/books/([^/]+?)/([^/]+?)(?:/)?$",
