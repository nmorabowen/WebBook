{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/books/[bookSlug]",
      "regex": "^/api/books/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPbookSlug": "nxtPbookSlug"
      },
      "namedRegex": "^/api/books/(?<nxtPbookSlug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/books/[bookSlug]/chapters",
      "regex": "^/api/books/([^/]+?)/chapters(?:/)?$",
      "routeKeys": {
        "nxtPbookSlug": "nxtPbookSlug"
      },
      "namedRegex": "^/api/books/(?<nxtPbookSlug>[^/]+?)/chapters(?:/)?$"
    },
    {
      "page": "/api/books/[bookSlug]/chapters/[chapterSlug]",
      "regex": "^/api/books/([^/]+?)/chapters/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPbookSlug": "nxtPbookSlug",
        "nxtPchapterSlug": "nxtPchapterSlug"
      },
      "namedRegex": "^/api/books/(?<nxtPbookSlug>[^/]+?)/chapters/(?<nxtPchapterSlug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/notes/[slug]",
